PUBLIC_API_URL="http://localhost:4000/api/v1"
API_PORT="4000"
API_DOCS_ENABLED="false"
PAYMENT_WEBHOOK_SECRET="replace-with-long-random-webhook-secret"
TRUST_PROXY="false"
