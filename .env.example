JWT_ACCESS_SECRET="replace-with-long-random-access-secret"
JWT_REFRESH_SECRET="replace-with-long-random-refresh-secret"
REDIS_URL="redis://localhost:6379"
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_MASTER_KEY="cofind_dev_master_key"
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="cofind-assets"
S3_ACCESS_KEY_ID="cofind"
S3_SECRET_ACCESS_KEY="cofind_dev_secret"
PUBLIC_WEB_URL="http://localhost:3000"
PUBLIC_API_BASE="http://localhost:4000/api/v1"
